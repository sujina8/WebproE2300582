/* ============================================================
   EduSkill – assets/css/Mijala.css
   ADMIN section styles
   Author: Mijala
   ============================================================ */

:root { --sidebar-w: 240px; --admin-accent: #c97b2e; }

/* ── Dark login page ── */
body.admin-login { background:#1e1a14; }
.admin-auth-wrap { min-height:100vh; display:flex; align-items:center; justify-content:center; padding:100px 20px 40px; background:linear-gradient(135deg,#1e1a14 0%,#2d2518 60%,#1e1a14 100%); }
.admin-card { background:#2a2218; border-radius:24px; padding:44px 40px; width:100%; max-width:440px; box-shadow:0 16px 56px rgba(0,0,0,.4); border:1px solid rgba(201,123,46,.25); }
.admin-card h2 { font-family:'Playfair Display',serif; font-size:1.6rem; text-align:center; margin-bottom:4px; color:white; }
.admin-card .sub { text-align:center; color:rgba(255,255,255,.5); font-size:.88rem; margin-bottom:28px; }
.admin-test-creds { background:rgba(201,123,46,.1); border:1px solid rgba(201,123,46,.25); border-radius:12px; padding:12px 16px; margin-bottom:22px; font-size:.82rem; }
.admin-test-creds strong { color:var(--primary-light); }
.admin-test-creds p { color:rgba(255,255,255,.6); margin-top:4px; line-height:1.6; }
.admin-test-creds code { color:#e8a44a; }
.admin-fg label { font-size:.8rem; font-weight:600; color:rgba(255,255,255,.6); display:block; margin-bottom:6px; }
.admin-input-wrap { position:relative; margin-bottom:14px; }
.admin-input-wrap .prefix { position:absolute; left:14px; top:50%; transform:translateY(-50%); color:rgba(255,255,255,.3); font-size:.85rem; }
.admin-input-wrap input { width:100%; padding:12px 14px 12px 38px; border-radius:10px; border:1.5px solid rgba(201,123,46,.25); background:rgba(255,255,255,.06); color:white; font-family:'DM Sans',sans-serif; font-size:.9rem; outline:none; transition:border-color .22s; }
.admin-input-wrap input::placeholder { color:rgba(255,255,255,.25); }
.admin-input-wrap input:focus { border-color:var(--primary); background:rgba(255,255,255,.1); box-shadow:0 0 0 3px rgba(201,123,46,.15); }
.admin-input-wrap .eye-btn { position:absolute; right:12px; top:50%; transform:translateY(-50%); background:none; border:none; cursor:pointer; color:rgba(255,255,255,.4); }
.admin-auth-btn { width:100%; padding:13px; border-radius:50px; background:var(--primary); color:white; border:none; font-family:'DM Sans',sans-serif; font-size:.97rem; font-weight:600; cursor:pointer; margin-top:6px; box-shadow:0 4px 18px rgba(201,123,46,.4); transition:background var(--transition),transform var(--transition); }
.admin-auth-btn:hover { background:var(--primary-dark); transform:translateY(-2px); }
.security-note { display:flex; align-items:center; gap:8px; margin-top:18px; padding:10px 14px; background:rgba(201,123,46,.08); border-radius:10px; font-size:.78rem; color:rgba(255,255,255,.45); }
.security-note i { color:var(--primary-light); }
.err-msg { background:rgba(220,38,38,.15); border:1px solid rgba(220,38,38,.3); color:#fca5a5; border-radius:10px; padding:10px 14px; font-size:.83rem; margin-bottom:14px; display:none; }
.err-msg.show { display:block; }

/* ── Dashboard layout ── */
.dash-layout { display:flex; min-height:100vh; padding-top:96px; }
.sidebar { width:var(--sidebar-w); flex-shrink:0; background:#1e1a14; padding:24px 0; position:fixed; top:96px; bottom:0; left:0; overflow-y:auto; z-index:100; }
.sidebar-logo { display:flex; align-items:center; gap:8px; padding:0 20px 20px; border-bottom:1px solid rgba(255,255,255,.08); margin-bottom:12px; font-family:'Playfair Display',serif; font-size:1.1rem; color:var(--primary-light); font-weight:700; }
.sidebar-label { padding:12px 20px 4px; font-size:.68rem; font-weight:700; color:rgba(255,255,255,.3); letter-spacing:.09em; text-transform:uppercase; }
.sidebar a { display:flex; align-items:center; gap:10px; padding:10px 20px; font-size:.87rem; font-weight:500; color:rgba(255,255,255,.55); transition:background .2s,color .2s; }
.sidebar a:hover  { background:rgba(255,255,255,.06); color:var(--primary-light); }
.sidebar a.active { background:rgba(201,123,46,.15); color:var(--primary-light); border-right:3px solid var(--primary); }
.sidebar a i { width:16px; font-size:.85rem; }
.sidebar .logout-link { color:rgba(220,38,38,.8)!important; margin-top:8px; }
.dash-main { flex:1; padding:32px; margin-left:var(--sidebar-w); max-width:1160px; background:var(--cream); min-height:100vh; }

/* ── Welcome banner ── */
.welcome-banner { background:linear-gradient(135deg,#1e1a14,#2d2518); border-radius:18px; padding:28px 32px; color:white; margin-bottom:28px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px; border:1px solid rgba(201,123,46,.2); }
.welcome-banner h2 { font-family:'Playfair Display',serif; font-size:1.5rem; margin-bottom:4px; }
.welcome-banner p  { opacity:.7; font-size:.9rem; }
.admin-badge { background:rgba(201,123,46,.15); color:var(--primary-light); padding:8px 16px; border-radius:50px; font-size:.82rem; font-weight:600; }

/* ── Stat grid ── */
.stat-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:18px; margin-bottom:28px; }
.stat-box { background:white; border-radius:var(--radius); padding:22px 20px; border:1px solid rgba(201,123,46,.1); box-shadow:0 3px 14px rgba(201,123,46,.07); }
.sb-icon { width:44px; height:44px; border-radius:12px; background:rgba(201,123,46,.1); display:flex; align-items:center; justify-content:center; margin-bottom:14px; }
.sb-icon i { color:var(--primary); font-size:1.1rem; }
.sb-icon.blue   { background:rgba(59,130,246,.1)!important; }
.sb-icon.blue i { color:#3b82f6!important; }
.sb-icon.green  { background:rgba(22,163,74,.1)!important; }
.sb-icon.green i{ color:#16a34a!important; }
.sb-icon.purple { background:rgba(139,92,246,.1)!important; }
.sb-icon.purple i { color:#8b5cf6!important; }
.sb-val  { font-family:'Playfair Display',serif; font-size:1.9rem; font-weight:700; color:var(--text-dark); }
.sb-label { font-size:.8rem; color:var(--text-light); margin-top:3px; }

/* ── Tab nav ── */
.tab-nav { display:flex; gap:4px; flex-wrap:wrap; background:white; border-radius:50px; padding:5px; border:1px solid rgba(201,123,46,.12); box-shadow:0 2px 10px rgba(201,123,46,.07); margin-bottom:24px; width:fit-content; }
.tab-btn { padding:9px 20px; border-radius:50px; border:none; background:none; font-family:'DM Sans',sans-serif; font-size:.87rem; font-weight:500; color:var(--text-mid); cursor:pointer; transition:all .22s; }
.tab-btn.active { background:var(--primary); color:white; box-shadow:0 4px 12px rgba(201,123,46,.3); }
.tab-btn:hover:not(.active) { background:var(--cream); color:var(--primary); }
.tab-pane { display:none; }
.tab-pane.active { display:block; }

/* ── Tables ── */
.table-wrap { background:white; border-radius:var(--radius); border:1px solid rgba(201,123,46,.1); box-shadow:0 3px 14px rgba(201,123,46,.06); overflow:hidden; margin-bottom:24px; }
.table-header { display:flex; align-items:center; justify-content:space-between; padding:18px 22px; border-bottom:1px solid var(--cream-dark); flex-wrap:wrap; gap:10px; }
.table-header h3 { font-size:1rem; font-weight:600; }
.table-search { padding:8px 14px; border-radius:50px; border:1.5px solid rgba(201,123,46,.2); background:var(--cream); font-family:'DM Sans',sans-serif; font-size:.85rem; outline:none; width:220px; }
table { width:100%; border-collapse:collapse; }
th { background:var(--cream); padding:11px 16px; text-align:left; font-size:.77rem; font-weight:700; color:var(--text-light); letter-spacing:.05em; text-transform:uppercase; }
td { padding:12px 16px; font-size:.87rem; color:var(--text-mid); border-bottom:1px solid var(--cream-dark); vertical-align:middle; }
tr:last-child td { border-bottom:none; }
tr:hover td { background:#fdf8f2; }

/* ── Approval cards ── */
.appr-card { background:white; border-radius:16px; padding:20px 22px; border:1px solid rgba(201,123,46,.1); box-shadow:0 3px 14px rgba(201,123,46,.06); margin-bottom:14px; display:flex; align-items:center; gap:16px; flex-wrap:wrap; }
.appr-icon { width:48px; height:48px; border-radius:14px; background:linear-gradient(135deg,#5b6cf6,#818cf8); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.appr-icon i { color:white; font-size:1.1rem; }
.appr-info { flex:1; min-width:160px; }
.appr-info h4 { font-weight:600; font-size:.97rem; margin-bottom:2px; }
.appr-info p  { font-size:.78rem; color:var(--text-light); }
.appr-actions { display:flex; gap:8px; }
.btn-approve { background:rgba(22,163,74,.1); color:#15803d; border:none; border-radius:8px; padding:8px 16px; font-size:.78rem; font-weight:600; cursor:pointer; font-family:'DM Sans',sans-serif; transition:background .2s; }
.btn-approve:hover { background:#16a34a; color:white; }
.btn-reject  { background:rgba(220,38,38,.08); color:#b91c1c; border:none; border-radius:8px; padding:8px 16px; font-size:.78rem; font-weight:600; cursor:pointer; font-family:'DM Sans',sans-serif; transition:background .2s; }
.btn-reject:hover  { background:#dc2626; color:white; }
.btn-view    { background:rgba(59,130,246,.1); color:#1d4ed8; border:none; border-radius:8px; padding:8px 14px; font-size:.78rem; font-weight:600; cursor:pointer; font-family:'DM Sans',sans-serif; transition:background .2s; }
.btn-view:hover    { background:#3b82f6; color:white; }

/* ── Form card ── */
.form-card { background:white; border-radius:var(--radius); padding:28px; border:1px solid rgba(201,123,46,.1); box-shadow:0 3px 14px rgba(201,123,46,.06); margin-bottom:24px; }
.form-card h3 { font-size:1rem; font-weight:600; margin-bottom:20px; }

/* ── Chart ── */
.chart-wrap  { display:flex; flex-direction:column; gap:10px; }
.chart-row   { display:flex; align-items:center; gap:10px; }
.chart-label { font-size:.8rem; color:var(--text-mid); width:60px; text-align:right; flex-shrink:0; }
.chart-outer { flex:1; height:24px; background:var(--cream-dark); border-radius:6px; overflow:hidden; }
.chart-inner { height:100%; border-radius:6px; background:linear-gradient(90deg,var(--primary),var(--primary-light)); transition:width 1.1s ease; }
.chart-val   { font-size:.8rem; font-weight:600; color:var(--text-dark); width:30px; flex-shrink:0; }

/* ── Empty state ── */
.empty-state { text-align:center; padding:40px; color:var(--text-light); }
.empty-state i { font-size:2.5rem; margin-bottom:10px; display:block; color:#22c55e; }

/* ── Responsive ── */
@media(max-width:768px) { .sidebar { display:none } .dash-main { margin-left:0 } }
@media(max-width:580px) { .stat-grid { grid-template-columns:1fr 1fr } .tab-nav { width:100% } }
