/* ============================================================
   EduSkill – assets/css/Sailabee.css
   TRAINING PROVIDER section styles
   Author: Sailabee
   ============================================================ */

:root { --sidebar-w: 240px; --provider-accent: #5b6cf6; --provider-dark: #4338ca; }

/* ── Auth page base styles (provider) ── */
.auth-wrap { min-height:100vh; display:flex; align-items:center; justify-content:center; padding:100px 20px 40px; background:linear-gradient(135deg,#f0f0ff 0%,#e8e8f8 60%,#d8d8f0 100%); }
.auth-card { background:white; border-radius:24px; padding:44px 40px; width:100%; max-width:480px; box-shadow:0 16px 56px rgba(91,108,246,0.15); border:1px solid rgba(91,108,246,0.12); }
.auth-icon { width:64px; height:64px; border-radius:50%; background:linear-gradient(135deg,var(--provider-accent),#8b5cf6); display:flex; align-items:center; justify-content:center; margin:0 auto 20px; box-shadow:0 8px 24px rgba(91,108,246,0.3); }
.auth-icon i { color:white; font-size:1.6rem; }
.auth-card h2 { font-family:'Playfair Display',serif; font-size:1.6rem; text-align:center; margin-bottom:4px; }
.auth-card .sub { text-align:center; color:var(--text-light); font-size:.88rem; margin-bottom:28px; }

/* ── Provider colour overrides on shared auth ── */
.auth-icon.prov-icon { background:linear-gradient(135deg,var(--provider-accent),#8b5cf6)!important; box-shadow:0 8px 24px rgba(91,108,246,0.3)!important; }
.auth-btn.prov-btn   { background:var(--provider-accent)!important; box-shadow:0 4px 18px rgba(91,108,246,0.3)!important; }
.auth-btn.prov-btn:hover { background:var(--provider-dark)!important; }

/* ── Auth card wider for register ── */
.auth-card.wide { max-width:580px; }
.auth-wrap.top-align { align-items:flex-start; padding-top:100px; }
.pending-note { background:rgba(245,158,11,.08); border:1px solid rgba(245,158,11,.25); border-radius:12px; padding:12px 16px; margin-bottom:22px; font-size:.83rem; color:#92400e; display:flex; gap:10px; align-items:flex-start; }
.pending-note i { color:#f59e0b; margin-top:2px; }
.pending-msg { background:rgba(245,158,11,.08); border:1px solid rgba(245,158,11,.25); color:#92400e; border-radius:10px; padding:10px 14px; font-size:.83rem; margin-bottom:14px; display:none; }
.pending-msg.show { display:block; }
.sec-divider { font-size:.78rem; font-weight:700; color:var(--text-light); letter-spacing:.08em; text-transform:uppercase; margin:10px 0 16px; padding-bottom:8px; border-bottom:1px solid var(--cream-dark); }
.terms { display:flex; align-items:flex-start; gap:10px; margin-bottom:16px; font-size:.82rem; color:var(--text-mid); }
.terms input[type=checkbox] { margin-top:3px; accent-color:var(--primary); }
.terms a { color:var(--primary); }
.input-wrap { position:relative; }
.input-wrap .prefix { position:absolute; left:14px; top:50%; transform:translateY(-50%); color:var(--text-light); font-size:.85rem; }
.input-wrap input, .input-wrap select { width:100%; padding:12px 14px 12px 38px; border-radius:10px; border:1.5px solid rgba(201,123,46,0.2); background:var(--cream); font-family:'DM Sans',sans-serif; font-size:.9rem; color:var(--text-dark); outline:none; transition:border-color .22s,box-shadow .22s; }
.input-wrap input:focus, .input-wrap select:focus { border-color:var(--primary); box-shadow:0 0 0 3px rgba(201,123,46,0.1); background:white; }
.eye-btn { position:absolute; right:12px; top:50%; transform:translateY(-50%); background:none; border:none; cursor:pointer; color:var(--text-light); }
.auth-btn { width:100%; padding:13px; border-radius:50px; background:var(--primary); color:white; border:none; font-family:'DM Sans',sans-serif; font-size:.97rem; font-weight:600; cursor:pointer; margin-top:6px; box-shadow:0 4px 18px rgba(201,123,46,0.3); transition:background var(--transition),transform var(--transition); }
.auth-btn:hover { background:var(--primary-dark); transform:translateY(-2px); }
.auth-footer { text-align:center; margin-top:20px; font-size:.85rem; color:var(--text-light); }
.auth-footer a { color:var(--primary); font-weight:600; }
.err-msg { background:rgba(220,38,38,0.08); border:1px solid rgba(220,38,38,0.2); color:#b91c1c; border-radius:10px; padding:10px 14px; font-size:.83rem; margin-bottom:14px; display:none; }
.err-msg.show { display:block; }
.test-creds { background:var(--cream); border:1px solid rgba(201,123,46,0.2); border-radius:12px; padding:12px 16px; margin-bottom:22px; font-size:.82rem; }
.test-creds strong { color:var(--primary); }
.test-creds p { color:var(--text-mid); margin-top:4px; line-height:1.6; }

/* ── Dashboard layout ── */
.dash-layout { display:flex; min-height:100vh; padding-top:96px; }
.sidebar { width:var(--sidebar-w); flex-shrink:0; background:white; border-right:1px solid rgba(91,108,246,0.12); padding:24px 0; position:fixed; top:96px; bottom:0; left:0; overflow-y:auto; z-index:100; }
.sidebar-logo { display:flex; align-items:center; gap:8px; padding:0 20px 20px; border-bottom:1px solid var(--cream-dark); margin-bottom:12px; font-family:'Playfair Display',serif; font-size:1.1rem; color:var(--provider-accent); font-weight:700; }
.sidebar-label { padding:12px 20px 4px; font-size:.68rem; font-weight:700; color:var(--text-light); letter-spacing:.09em; text-transform:uppercase; }
.sidebar a { display:flex; align-items:center; gap:10px; padding:10px 20px; font-size:.87rem; font-weight:500; color:var(--text-mid); transition:background .2s,color .2s; }
.sidebar a:hover  { background:#f0f0ff; color:var(--provider-accent); }
.sidebar a.active { background:rgba(91,108,246,0.1); color:var(--provider-accent); border-right:3px solid var(--provider-accent); }
.sidebar a i { width:16px; font-size:.85rem; }
.sidebar .logout-link { color:#b91c1c!important; margin-top:8px; }
.dash-main { flex:1; padding:32px; margin-left:var(--sidebar-w); max-width:1160px; }

/* ── Welcome banner ── */
.welcome-banner { background:linear-gradient(135deg,var(--provider-accent),var(--provider-dark)); border-radius:18px; padding:28px 32px; color:white; margin-bottom:28px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px; }
.welcome-banner h2 { font-family:'Playfair Display',serif; font-size:1.5rem; margin-bottom:4px; }
.welcome-banner p  { opacity:.85; font-size:.9rem; }

/* ── Stat grid ── */
.stat-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:18px; margin-bottom:28px; }
.stat-box { background:white; border-radius:var(--radius); padding:22px 20px; border:1px solid rgba(91,108,246,0.1); box-shadow:0 3px 14px rgba(91,108,246,0.06); }
.sb-icon { width:44px; height:44px; border-radius:12px; background:rgba(91,108,246,0.1); display:flex; align-items:center; justify-content:center; margin-bottom:14px; }
.sb-icon i { color:var(--provider-accent); font-size:1.1rem; }
.sb-icon.amber { background:rgba(201,123,46,0.1)!important; }
.sb-icon.amber i { color:var(--primary)!important; }
.sb-icon.green { background:rgba(22,163,74,0.1)!important; }
.sb-icon.green i { color:#16a34a!important; }
.sb-val  { font-family:'Playfair Display',serif; font-size:1.9rem; font-weight:700; color:var(--text-dark); }
.sb-label { font-size:.8rem; color:var(--text-light); margin-top:3px; }

/* ── Tab nav ── */
.tab-nav { display:flex; gap:4px; flex-wrap:wrap; background:white; border-radius:50px; padding:5px; border:1px solid rgba(91,108,246,0.12); box-shadow:0 2px 10px rgba(91,108,246,0.07); margin-bottom:24px; width:fit-content; }
.tab-btn { padding:9px 20px; border-radius:50px; border:none; background:none; font-family:'DM Sans',sans-serif; font-size:.87rem; font-weight:500; color:var(--text-mid); cursor:pointer; transition:all .22s; }
.tab-btn.active { background:var(--provider-accent); color:white; box-shadow:0 4px 12px rgba(91,108,246,0.3); }
.tab-btn:hover:not(.active) { background:#f0f0ff; color:var(--provider-accent); }
.tab-pane { display:none; }
.tab-pane.active { display:block; }

/* ── Course management cards ── */
.cm-card { background:white; border-radius:16px; padding:20px; border:1px solid rgba(91,108,246,0.1); box-shadow:0 3px 14px rgba(91,108,246,0.06); margin-bottom:14px; display:flex; align-items:center; gap:16px; flex-wrap:wrap; }
.cm-icon { width:52px; height:52px; border-radius:14px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.cm-icon i { font-size:1.3rem; color:white; }
.cm-info { flex:1; min-width:160px; }
.cm-info h4 { font-weight:600; font-size:.97rem; margin-bottom:3px; }
.cm-info p  { font-size:.78rem; color:var(--text-light); }
.cm-stats { display:flex; gap:18px; flex-wrap:wrap; }
.cm-stat strong { display:block; font-family:'Playfair Display',serif; font-size:1.2rem; color:var(--text-dark); }
.cm-stat span   { font-size:.72rem; color:var(--text-light); }
.cm-actions { display:flex; gap:8px; }
.btn-edit { background:rgba(59,130,246,0.1); color:#1d4ed8; border:none; border-radius:8px; padding:7px 14px; font-size:.78rem; font-weight:600; cursor:pointer; font-family:'DM Sans',sans-serif; transition:background .2s; }
.btn-edit:hover { background:#3b82f6; color:white; }
.btn-del { background:rgba(220,38,38,0.08); color:#b91c1c; border:none; border-radius:8px; padding:7px 14px; font-size:.78rem; font-weight:600; cursor:pointer; font-family:'DM Sans',sans-serif; transition:background .2s; }
.btn-del:hover  { background:#dc2626; color:white; }

/* ── Table ── */
.table-wrap { background:white; border-radius:var(--radius); border:1px solid rgba(91,108,246,0.1); box-shadow:0 3px 14px rgba(91,108,246,0.06); overflow:hidden; margin-bottom:24px; }
.table-header { display:flex; align-items:center; justify-content:space-between; padding:18px 22px; border-bottom:1px solid var(--cream-dark); }
.table-header h3 { font-size:1rem; font-weight:600; }
table { width:100%; border-collapse:collapse; }
th { background:#f8f8ff; padding:11px 16px; text-align:left; font-size:.77rem; font-weight:700; color:var(--text-light); letter-spacing:.05em; text-transform:uppercase; }
td { padding:12px 16px; font-size:.87rem; color:var(--text-mid); border-bottom:1px solid var(--cream-dark); vertical-align:middle; }
tr:last-child td { border-bottom:none; }
tr:hover td { background:#f8f8ff; }

/* ── Form card ── */
.form-card { background:white; border-radius:var(--radius); padding:28px; border:1px solid rgba(91,108,246,0.1); box-shadow:0 3px 14px rgba(91,108,246,0.06); margin-bottom:24px; }
.form-card h3 { font-size:1rem; font-weight:600; margin-bottom:20px; }

/* ── Teaching materials page ── */
.material-card { background:white; border-radius:16px; padding:20px; border:1px solid rgba(91,108,246,0.1); box-shadow:0 3px 14px rgba(91,108,246,0.06); margin-bottom:14px; display:flex; align-items:center; gap:16px; }
.mat-icon { width:48px; height:48px; border-radius:12px; background:rgba(91,108,246,0.1); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.mat-icon i { font-size:1.2rem; color:var(--provider-accent); }
.mat-info { flex:1; }
.mat-info h4 { font-weight:600; font-size:.95rem; margin-bottom:3px; }
.mat-info p  { font-size:.78rem; color:var(--text-light); }
.mat-actions { display:flex; gap:8px; }
.upload-zone { border:2px dashed rgba(91,108,246,0.3); border-radius:14px; padding:40px; text-align:center; background:#f8f8ff; cursor:pointer; transition:border-color .2s,background .2s; }
.upload-zone:hover { border-color:var(--provider-accent); background:#f0f0ff; }
.upload-zone i { font-size:2.5rem; color:rgba(91,108,246,0.4); margin-bottom:12px; display:block; }
.upload-zone p { font-size:.88rem; color:var(--text-mid); }
.upload-zone strong { color:var(--provider-accent); }

/* ── Course teaching/lesson page ── */
.lesson-editor { background:white; border-radius:16px; padding:24px; border:1px solid rgba(91,108,246,0.1); box-shadow:0 3px 14px rgba(91,108,246,0.06); margin-bottom:20px; }
.lesson-editor h3 { font-size:1rem; font-weight:600; margin-bottom:16px; }
.lesson-list-item { display:flex; align-items:center; gap:12px; padding:12px 16px; border-radius:10px; background:var(--cream); margin-bottom:8px; cursor:grab; }
.lesson-list-item:last-child { margin-bottom:0; }
.lesson-list-item i.drag { color:var(--text-light); cursor:grab; }
.lesson-list-item .l-title { flex:1; font-size:.88rem; font-weight:500; }
.lesson-list-item .l-type { font-size:.72rem; padding:3px 10px; border-radius:50px; background:rgba(91,108,246,0.1); color:var(--provider-accent); font-weight:600; }

/* ── Profile ── */
.p-hero { background:linear-gradient(135deg,var(--provider-accent),var(--provider-dark)); padding:100px 24px 50px; }
.p-inner { max-width:1160px; margin:0 auto; display:flex; align-items:center; gap:24px; flex-wrap:wrap; }
.org-av { width:80px; height:80px; border-radius:20px; background:rgba(255,255,255,.2); border:2px solid rgba(255,255,255,.4); display:flex; align-items:center; justify-content:center; font-size:1.8rem; color:white; flex-shrink:0; }
.p-info h2 { font-family:'Playfair Display',serif; color:white; font-size:1.5rem; margin-bottom:4px; }
.p-info p  { color:rgba(255,255,255,.72); font-size:.87rem; }
.chips { display:flex; gap:8px; margin-top:10px; flex-wrap:wrap; }
.chip { background:rgba(255,255,255,.18); color:white; border:1px solid rgba(255,255,255,.3); border-radius:50px; padding:4px 12px; font-size:.76rem; }
.p-body { max-width:1160px; margin:0 auto; padding:40px 24px 60px; display:grid; grid-template-columns:240px 1fr; gap:24px; }
.p-nav { background:white; border-radius:16px; padding:16px 0; border:1px solid rgba(91,108,246,0.1); box-shadow:0 3px 14px rgba(91,108,246,0.06); height:fit-content; position:sticky; top:90px; }
.p-nav a { display:flex; align-items:center; gap:10px; padding:11px 20px; font-size:.87rem; font-weight:500; color:var(--text-mid); transition:background .2s,color .2s; text-decoration:none; border-right:3px solid transparent; }
.p-nav a i { width:16px; font-size:.85rem; flex-shrink:0; }
/* Tab links – highlight when active/hovered */
.p-nav a.tab-link:hover,
.p-nav a.tab-link.active { background:#f0f0ff; color:var(--provider-accent); border-right-color:var(--provider-accent); }
/* Utility links (Dashboard, Logout) – subtle hover, no bar */
.p-nav a.util-link { margin-top:2px; }
.p-nav a.util-link:hover { background:#f0f0ff; }
.p-nav .p-nav-divider { height:1px; background:var(--cream-dark); margin:8px 16px; }
.form-card { background:white; border-radius:var(--radius); padding:28px; border:1px solid rgba(91,108,246,0.1); box-shadow:0 3px 14px rgba(91,108,246,0.06); margin-bottom:24px; }
.sec-title { font-family:'Playfair Display',serif; font-size:1rem; margin-bottom:18px; padding-bottom:10px; border-bottom:1px solid var(--cream-dark); }
.tab-pane { display:none; }
.tab-pane.active { display:block; }

/* ── Chart ── */
.chart-wrap  { display:flex; flex-direction:column; gap:10px; }
.chart-row   { display:flex; align-items:center; gap:10px; }
.chart-label { font-size:.8rem; color:var(--text-mid); width:60px; text-align:right; flex-shrink:0; }
.chart-outer { flex:1; height:24px; background:var(--cream-dark); border-radius:6px; overflow:hidden; }
.chart-inner { height:100%; border-radius:6px; background:linear-gradient(90deg,var(--provider-accent),#818cf8); transition:width 1.1s ease; }
.chart-val   { font-size:.8rem; font-weight:600; color:var(--text-dark); width:30px; flex-shrink:0; }

/* ── Responsive ── */
@media(max-width:900px) { .p-body { grid-template-columns:1fr } }
@media(max-width:768px) { .sidebar { display:none } .dash-main { margin-left:0; max-width:100% } }
@media(max-width:580px) { .p-nav { position:static; display:flex; overflow-x:auto; padding:10px; gap:4px } .p-nav a { white-space:nowrap; border-right:none!important; border-radius:50px; padding:8px 14px } .p-nav .p-nav-divider { display:none } .stat-grid { grid-template-columns:1fr 1fr } }
